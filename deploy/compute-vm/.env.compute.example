# Compute VM environment variables
# Copy to .env and fill in values

DATABASE_URL=postgresql+asyncpg://sp_user:CHANGE_ME@DOCKER_VM_INTERNAL_IP:5432/stock_predictor
REDIS_URL=redis://:CHANGE_ME@DOCKER_VM_INTERNAL_IP:6379/0

# FinBERT
FINBERT_MODEL_PATH=ProsusAI/finbert
FINBERT_BATCH_SIZE=16
FINBERT_MAX_LENGTH=512

# External APIs
POLYGON_API_KEY=CHANGE_ME
REDDIT_CLIENT_ID=CHANGE_ME
REDDIT_CLIENT_SECRET=CHANGE_ME
REDDIT_USER_AGENT=stock-predictor/1.0

# Alerts
DISCORD_WEBHOOK_URL=CHANGE_ME
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Logging
LOG_LEVEL=INFO

# Data retention (days)
RETENTION_ARTICLE_TEXT_DAYS=90
RETENTION_SCRAPE_LOG_DAYS=30
RETENTION_ALERT_LOG_DAYS=90
RETENTION_SIGNAL_DAYS=180
