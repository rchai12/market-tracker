# Docker VM environment variables
# Copy to project root as .env and fill in values

POSTGRES_DB=stock_predictor
POSTGRES_USER=sp_user
POSTGRES_PASSWORD=CHANGE_ME

REDIS_PASSWORD=CHANGE_ME

SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
ENVIRONMENT=production
ALLOWED_ORIGINS=https://yourdomain.com

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DISCORD_WEBHOOK_URL=CHANGE_ME
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Logging
LOG_LEVEL=INFO

# Data retention (days)
RETENTION_ARTICLE_TEXT_DAYS=90
RETENTION_SCRAPE_LOG_DAYS=30
RETENTION_ALERT_LOG_DAYS=90
RETENTION_SIGNAL_DAYS=180

# Network binding (set to VPC IP to allow compute VM access)
POSTGRES_BIND_IP=127.0.0.1
REDIS_BIND_IP=127.0.0.1

# Domain for SSL/nginx
DOMAIN=yourdomain.com

# Flower (Celery monitoring) — access via SSH tunnel to :5555
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME
FLOWER_BIND_IP=127.0.0.1
